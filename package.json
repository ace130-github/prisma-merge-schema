{
  "name": "prisma-merge-schema",
  "description": "Merges/postfixes Prisma (v2) schemas",
  "version": "1.0.0",
  "author": "Stephen McElhinney @smcelhinney",
  "bin": {
    "prisma-merge-schema": "./bin/run"
  },
  "bugs": "https://github.com/smcelhinney/prisma-merge-schema",
  "dependencies": {
    "@oclif/core": "^3",
    "@oclif/plugin-help": "^5",
    "glob": "^10",
    "is-glob": "^4.0.1",
    "tslib": "^2"
  },
  "devDependencies": {
    "@oclif/test": "^4",
    "@types/chai": "^4",
    "@types/is-glob": "^4.0.1",
    "@types/mocha": "^10",
    "@types/node": "^20",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "c8": "^10",
    "chai": "^4",
    "eslint": "^9",
    "eslint-config-oclif": "^5",
    "eslint-config-oclif-typescript": "^3",
    "mocha": "^11",
    "oclif": "^4",
    "ts-node": "^10",
    "typescript": "^5"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "/bin",
    "/lib"
  ],
  "homepage": "https://github.com/smcelhinney/prisma-merge-schema",
  "keywords": [
    "oclif"
  ],
  "license": "MIT",
  "main": "lib/index.js",
  "oclif": {
    "bin": "prisma-merge-schema"
  },
  "repository": "smcelhinney/prisma-merge-schema",
  "scripts": {
    "merge-test": "node bin/run --datasource test/resources/base.prisma --decorators test/resources/decorators.prisma --outputFile test/resources/merged.prisma",
    "posttest": "eslint .",
    "prepack": "rm -rf lib && tsc -b && oclif readme",
    "test": "c8 mocha --forbid-only \"test/**/*.test.ts\"",
    "version": "oclif readme && git add README.md"
  },
  "types": "lib/index.d.ts",
  "overrides": {
    "diff": "^8.0.3",
    "fast-xml-parser": "^5.3.8",
    "minimatch": "^10.0.0",
    "serialize-javascript": "^7.0.3",
    "mocha": {
      "serialize-javascript": "^7.0.3"
    }
  }
}
